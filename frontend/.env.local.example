# AMPS Frontend — Environment Variables
#
# Copy this file to .env.local for local development.
# In Vercel: set these in Project Settings → Environment Variables.
#
# .env.local is git-ignored by Next.js by default.
# NEVER commit real .env.local values.

# URL of the running AMPS backend API.
# Local dev:  http://localhost:8000
# Production: https://your-backend-host.example.com  (no trailing slash)
#
# This variable is inlined into the browser bundle at build time.
# If you change it after deployment, you must re-deploy.
NEXT_PUBLIC_API_URL=http://localhost:8000
