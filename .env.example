# AMPS Environment Variables
# Copy to .env and fill in values before running.

# Backend
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000
AUDIT_QUALITY_THRESHOLD=0.70
POLLING_INTERVAL_SECONDS=5

# Buyer onboarding — URL ingestion
# INGESTION_PROVIDER: "http" (default, real HTTP fetch) | "mock" (always use mock content)
INGESTION_PROVIDER=http
# INGESTION_FALLBACK_TO_MOCK: if "true", falls back to mock content when HTTP fetch fails
INGESTION_FALLBACK_TO_MOCK=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
